# Google OAuth 2.0 Credentials
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# The OAuth callback URL (must match what you configure in Google Cloud Console)
# For local development:
GOOGLE_REDIRECT_URI=http://localhost/api/auth/google/callback
# For production (replace with your Replit domain):
# GOOGLE_REDIRECT_URI=https://your-app.replit.app/api/auth/google/callback

# Session secret (generate a strong random string)
SESSION_SECRET=generate-a-strong-random-secret-here

# Database (auto-provisioned by Replit - do not change)
# DATABASE_URL=postgresql://...
